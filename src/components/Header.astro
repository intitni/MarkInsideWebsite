---
import LanguageSelect from "@astrojs/starlight/components/LanguageSelect.astro";
import { Icon } from "@astrojs/starlight/components";

const pathname = Astro.url.pathname;
const isChinese = pathname.startsWith("/zh-cn");

const changeLogURL = isChinese ? "/zh-cn/changelog" : "/changelog";
const privacyPolicyURL = isChinese
  ? "/zh-cn/privacy-policy"
  : "/privacy-policy";
const templatesPath = isChinese ? "/zh-cn/templates" : "/templates";
const agentPath = isChinese
  ? "/zh-cn/cooperate-with-agent"
  : "/cooperate-with-agent";

const i18n = isChinese
  ? {
      changelogTitle: "版本记录",
      privacyPolicyTitle: "隐私协议",
      templatesTitle: "模板",
      agentTitle: "AI",
    }
  : {
      changelogTitle: "Changelog",
      privacyPolicyTitle: "Privacy Policy",
      templatesTitle: "Templates",
      agentTitle: "AI",
    };
---

<div class="header-inner">
  <div class="flex items-center space-x-1">
    <details class="relative min-[50rem]:hidden m-0 flex items-center">
      <summary
        class="menu-summary text-[0.85rem] pr-4 py-1 cursor-pointer select-none"
        ><Icon name="bars" /></summary
      >
      <nav
        class="absolute left-0 top-[calc(100%+0.5rem)] flex flex-col min-w-44 gap-[0.55rem] px-[0.8rem] py-[0.65rem] rounded-lg bg-white text-gray-700 backdrop-blur-[14px] border border-white/20 z-20 shadow-2xl"
        aria-label="Site links"
      >
        <a class="nav-link" href={changeLogURL}>{i18n.changelogTitle}</a>
        <a class="nav-link" href={privacyPolicyURL}>{i18n.privacyPolicyTitle}</a
        >
        <a class="nav-link" href={templatesPath}>{i18n.templatesTitle}</a>
        <a class="nav-link ai-link" href={agentPath}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" aria-hidden="true"><path d="M13.95 6.805l.654 3.06c.593 2.773 2.759 4.939 5.532 5.532l3.06.654c1.024.219 1.024 1.68 0 1.899l-3.06.654c-2.773.593-4.939 2.759-5.532 5.532l-.654 3.06c-.219 1.024-1.68 1.024-1.899 0l-.654-3.06c-.593-2.773-2.759-4.939-5.532-5.532l-3.06-.654c-1.024-.219-1.024-1.68 0-1.899l3.06-.654c2.773-.593 4.939-2.759 5.532-5.532l.654-3.06C12.269 5.781 13.731 5.781 13.95 6.805zM23.641 2.525l.588 2.119c.152.547.58.975 1.127 1.127l2.119.588c.65.18.65 1.102 0 1.282l-2.119.588c-.547.152-.975.58-1.127 1.127l-.588 2.119c-.18.65-1.102.65-1.282 0l-.588-2.119c-.152-.547-.58-.975-1.127-1.127l-2.119-.588c-.65-.18-.65-1.102 0-1.282l2.119-.588c.547-.152.975-.58 1.127-1.127l.588-2.119C22.539 1.875 23.461 1.875 23.641 2.525z"/></svg>
          {i18n.agentTitle}
        </a>
      </nav>
    </details>

    <div
      class="title-wrapper sl-flex pl-1! pr-2! py-1! rounded-lg bg-white/12 print:hidden"
    >
      <a
        href={isChinese ? "/zh-cn" : "/"}
        class="flex shadow-none! hover:shadow-none! items-center space-x-1!"
        aria-label="MarkInside Home"
      >
        <img src="/AppIcon.png" alt="MarkInside" class="h-8 w-8 mr-2" />
        <span class="font-bold text-sm">MarkInside</span>
      </a>
    </div>
  </div>
  <div class="sl-flex print:hidden right-group">
    <nav
      class="hidden min-[50rem]:flex gap-4 items-center flex-wrap text-[0.85rem]"
      aria-label="Site links"
    >
      <a class="nav-link" href={changeLogURL}>{i18n.changelogTitle}</a>
      <a class="nav-link" href={privacyPolicyURL}>{i18n.privacyPolicyTitle}</a>
      <a class="nav-link" href={templatesPath}>{i18n.templatesTitle}</a>
      <a class="nav-link ai-link" href={agentPath}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" aria-hidden="true"><path d="M13.95 6.805l.654 3.06c.593 2.773 2.759 4.939 5.532 5.532l3.06.654c1.024.219 1.024 1.68 0 1.899l-3.06.654c-2.773.593-4.939 2.759-5.532 5.532l-.654 3.06c-.219 1.024-1.68 1.024-1.899 0l-.654-3.06c-.593-2.773-2.759-4.939-5.532-5.532l-3.06-.654c-1.024-.219-1.024-1.68 0-1.899l3.06-.654c2.773-.593 4.939-2.759 5.532-5.532l.654-3.06C12.269 5.781 13.731 5.781 13.95 6.805zM23.641 2.525l.588 2.119c.152.547.58.975 1.127 1.127l2.119.588c.65.18.65 1.102 0 1.282l-2.119.588c-.547.152-.975.58-1.127 1.127l-.588 2.119c-.18.65-1.102.65-1.282 0l-.588-2.119c-.152-.547-.58-.975-1.127-1.127l-2.119-.588c-.65-.18-.65-1.102 0-1.282l2.119-.588c.547-.152.975-.58 1.127-1.127l.588-2.119C22.539 1.875 23.461 1.875 23.641 2.525z"/></svg>
        {i18n.agentTitle}
      </a>
    </nav>

    <LanguageSelect />
  </div>
</div>

<style>
  @layer starlight.core {
    :global(.page > header.header) {
      border-bottom: none;
      background-color: rgb(62 111 207 / 0.42);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }

    .header-inner {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }

    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    .right-group {
      gap: 1rem;
      align-items: center;
    }

    .menu-summary::-webkit-details-marker {
      display: none;
    }

    .menu-summary {
      list-style: none;
    }

    .menu-summary::marker {
      content: "";
    }

    .ai-link {
      display: inline-flex;
      align-items: center;
      gap: 0.25em;
    }

    .ai-link svg {
      width: 1em;
      height: 1em;
      fill: currentColor;
      flex-shrink: 0;
    }
  }
</style>
