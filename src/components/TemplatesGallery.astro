---
import { Icon } from "@astrojs/starlight/components";

interface Props {
  locale: "en" | "zh-cn";
}

const { locale } = Astro.props;
const isChinese = locale === "zh-cn";

const title = isChinese ? "模板 (v1.3.0+)" : "Templates (v1.3.0+)";
const intro = isChinese
  ? "MarkInside 中的模板就像很多其他 app 中的插件那样，能够绕过懒惰的开发者为 MarkInside 带来更多的功能。"
  : "Templates in MarkInside are like plugins in other apps. It helps you to enhance MarkInside without asking the lazy developer.";
const usage = isChinese
  ? "只需要将下方的图片拖入模板文件夹即可安装对应模板。模板文件夹可以通过点击菜单栏的 <code>文件 > 模板收藏夹 > 打开模板文件夹</code> 打开。添加之后，模板会出现在 <code>模板收藏夹</code> 中。<br/><br/>你也可以把模板放在任意位置，并通过菜单栏的 <code>文件 > 使用模板</code> 使用它们。实际上所有通过 MarkInside 生成的图片都能作为模板使用。"
  : "To install a template, just drag the images below into the template folder. You can open the template folder by clicking <code>File > Template Collection > Open Template Folder</code> from the menu bar. The installed templates will be available in the <code>Template Collection</code> after that.<br/><br/>You can also store the templates anywhere and use them by clicking <code>File > Use Template</code>. All files created by MarkInside can be used as templates.";

const cards = isChinese
  ? [
      {
        title: "二维码",
        intro:
          '使用 <a href="https://github.com/nimiq/qr-creator/">qr-creator</a> 创建二维码。',
        imagePath: "/templates/QRCode.markinside.template.png",
      },
      {
        title: "Markdown",
        intro:
          '使用 <a href="https://marked.js.org/">marked</a> 渲染 markdown。<br/><br/>因为 markdown 支持表格，如果你想快速地创建表格，也可以使用这个模板。',
        imagePath: "/templates/Markdown.markinside.template.png",
      },
      {
        title: "思维导图",
        intro:
          '使用 <a href="https://markmap.js.org">markmap</a> 通过 markdown 创建思维导图。',
        imagePath: "/templates/MindMap.markinside.template.png",
      },
      {
        title: "代码高亮",
        intro:
          '使用 <a href="https://prismjs.com">Prism</a> 高亮代码。<br/><br/>模板支持的插件有：<br/>- 行高亮（Line Highlight）<br/>- 显示行标（Line Numbers）<br/>- 高亮 Diff（Diff Highlight）<br/><br/>你可以根据自己的需求修改模板增加其他插件。',
        imagePath: "/templates/SyntaxHighlighting.markinside.template.png",
      },
    ]
  : [
      {
        title: "QRCode",
        intro:
          'Generate QRCode of input texts. Powered by <a href="https://github.com/nimiq/qr-creator/">qr-creator</a>.',
        imagePath: "/templates/QRCode.markinside.template.png",
      },
      {
        title: "Markdown",
        intro:
          'Render markdown into image. Powered by <a href="https://marked.js.org/">marked</a>.<br/><br/>This template is also helpful when you need to create tables.',
        imagePath: "/templates/Markdown.markinside.template.png",
      },
      {
        title: "Mind Map",
        intro:
          'Create mind map by writing markdown. Powered by <a href="https://markmap.js.org">markmap</a>.',
        imagePath: "/templates/MindMap.markinside.template.png",
      },
      {
        title: "Syntax Highlighting",
        intro:
          'Highlight the syntax of your code. Powered by <a href="https://prismjs.com">Prism</a>.<br/><br/>The currently supported plugins in this template are:<br/>- Line Highlight<br/>- Line Numbers<br/>- Diff Highlight<br/><br/>But you are always free to mutate the template and add more plugins!',
        imagePath: "/templates/SyntaxHighlighting.markinside.template.png",
      },
    ];
---

<section
  class="template-gallery [&_p]:text-[1em] [&_p]:leading-[1.3em] [&_p]:mb-[0.7em] [&_a]:text-white [&_ul]:mb-[1.1em] [&_li]:list-square [&_li]:list-inside"
>
  <h2 class="flex flex-row items-center space-x-1 text-left">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="w-[1em] h-[1em]"
    >
      <path
        d="M11.25 5.337c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.036 1.007-1.875 2.25-1.875S15 2.34 15 3.375c0 .369-.128.713-.349 1.003-.215.283-.401.604-.401.959 0 .332.278.598.61.578 1.91-.114 3.79-.342 5.632-.676a.75.75 0 01.878.645 49.17 49.17 0 01.376 5.452.657.657 0 01-.66.664c-.354 0-.675-.186-.958-.401a1.647 1.647 0 00-1.003-.349c-1.035 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401.31 0 .557.262.534.571a48.774 48.774 0 01-.595 4.845.75.75 0 01-.61.61c-1.82.317-3.673.533-5.555.642a.58.58 0 01-.611-.581c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.035-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959a.641.641 0 01-.658.643 49.118 49.118 0 01-4.708-.36.75.75 0 01-.645-.878c.293-1.614.504-3.257.629-4.924A.53.53 0 005.337 15c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.036 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.369 0 .713.128 1.003.349.283.215.604.401.959.401a.656.656 0 00.659-.663 47.703 47.703 0 00-.31-4.82.75.75 0 01.83-.832c1.343.155 2.703.254 4.077.294a.64.64 0 00.657-.642z"
      ></path>
    </svg>
    <span>{title}</span>
  </h2>

  <p set:html={intro} />

  <div class="p-4 pb-3 bg-slate-300/20 rounded-lg text-[0.8em]">
    <p class="mb-0" set:html={usage} />
  </div>

  {
    cards.map((card) => (
      <div class="mx-auto my-8 text-sm">
        <h3 class="text-lg font-bold">{card.title}</h3>
        <p set:html={card.intro} />
        <div class="bg-blue-100 flex items-center justify-center p-2 rounded-lg border relative">
          <img
            src={`${card.imagePath}?rad=${Math.floor(Math.random() * 9000 + 1000)}`}
            alt={card.title}
            class="max-w-[70%] max-h-75 drop-shadow-2xl"
          />
          <a
            href={card.imagePath}
            download
            class="absolute top-1 right-1 py-1! px-2! border border-slate-300 rounded bg-slate-50 drop-shadow-2xl text-slate-500 text-xs shadow-none hover:shadow-none"
            aria-label={`Download ${card.title}`}
          >
            <Icon name="cloud-download" size="24px" class="fill-gray-500"/>
          </a>
        </div>
      </div>
    ))
  }
</section>
